# 从指定品种池随机抽一条碎碎念。
# avoid_index：上一条的下标，尽量不连续重复；池小于2条时忽略。
static func draw_phrase(breed: String, avoid_index: int = -1) -> Dictionary:
	var pool: Array = CHATTER_POOLS.get(breed, CHATTER_POOLS["orange"])
	if pool.is_empty():
		return {"index": -1, "phrase": ""}
	var idx: int = randi() % pool.size()
	if pool.size() > 1 and idx == avoid_index:
		idx = (idx + 1) % pool.size()
	return {"index": idx, "phrase": String(pool[idx])}

# 随机取一条散步小结趣味文案。
static func draw_summary_message(breed: String) -> String:
	var pool: Array = SUMMARY_MESSAGES.get(breed, SUMMARY_MESSAGES["orange"])
	if pool.is_empty():
		return "今天也走了很多步。"
	return String(pool[randi() % pool.size()])
